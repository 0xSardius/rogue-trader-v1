{
  "name": "rogue-trader-v1",
  "version": "0.1.0",
  "private": true,
  "description": "Solana autonomous trading swarm — pluggable strategy agents on the MAHORAGA pattern, brained by SolEnrich",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply rogue-trader-db",
    "db:migrate:local": "wrangler d1 migrations apply rogue-trader-db --local",
    "tail": "wrangler tail",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && echo 'Types OK'"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.80.0"
  }
}
